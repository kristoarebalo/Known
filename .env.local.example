# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE

# Create a product in Stripe dashboard for "Discovery Suite Results"
# then paste the price ID here (e.g. price_1ABC...)
NEXT_PUBLIC_RESULTS_PRICE_ID=price_YOUR_PRICE_ID_HERE
STRIPE_RESULTS_PRICE=price_YOUR_PRICE_ID_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ─── Resend (email) ───────────────────────────────────────────────────────────
# Get from https://resend.com
RESEND_API_KEY=re_YOUR_KEY_HERE
RESEND_FROM_EMAIL=results@yourdomain.com
